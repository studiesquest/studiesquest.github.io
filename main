const grid = document.getElementById("gridContainer");
const modal = document.getElementById("modal");
const gameFrame = document.getElementById("gameFrame");
const homeBtn = document.getElementById("homeBtn");

// Create tiles
games.forEach(game => {
    const tile = document.createElement("div");
    tile.className = "game-tile";
    tile.dataset.signin = game.signIn;
    tile.dataset.normal = game.normal;
    tile.dataset.title = game.title.toLowerCase();

    tile.innerHTML = `
        <img src="${game.thumbnail}" alt="${game.title}">
        <h2>${game.title}</h2>
        <p>${game.description}</p>
        <p><strong>Sign-in:</strong> ${game.signIn}</p>
        <p><strong>Normal:</strong> ${game.normal}</p>
    `;
    grid.appendChild(tile);

    tile.addEventListener("click", () => {
        gameFrame.src = game.src;
        modal.style.display = "flex";
    });
});

homeBtn.addEventListener("click", () => {
    modal.style.display = "none";
    gameFrame.src = "";
});

// Search
document.getElementById("searchInput").addEventListener("input", e => {
    const q = e.target.value.toLowerCase();
    document.querySelectorAll(".game-tile").forEach(t => {
        t.style.display = t.dataset.title.includes(q) ? "" : "none";
    });
});

// Filters
document.querySelectorAll("#filterButtons .filter-btn").forEach(btn => {
    btn.addEventListener("click", () => {
        const filter = btn.textContent;
        document.querySelectorAll(".game-tile").forEach(t => {
            if(filter === "All" || t.dataset.signin === filter || t.dataset.normal === filter) {
                t.style.display = "";
            } else {
                t.style.display = "none";
            }
        });
    });
});
